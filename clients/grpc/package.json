{
  "name": "@heddleco/grpc",
  "version": "0.7.1",
  "description": "Generated TypeScript protobuf and Connect clients for Heddle gRPC.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HeddleCo/heddle.git",
    "directory": "clients/grpc"
  },
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./gen/*": {
      "types": "./dist/src/gen/*.d.ts",
      "import": "./dist/src/gen/*.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "generate": "cargo run --locked -p heddle-devtools -- grpc-ts",
    "generate:check": "cargo run --locked -p heddle-devtools -- grpc-ts --check",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@connectrpc/connect": "^2.1.1"
  },
  "devDependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@connectrpc/connect": "^2.1.1",
    "@bufbuild/protoc-gen-es": "^2.12.0",
    "typescript": "^5.4.0"
  }
}
